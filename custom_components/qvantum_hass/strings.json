  "services": {
    "activate_extra_hot_water": {
      "name": "Activate extra hot water",
      "description": "Activates extra hot water mode for a specified duration",
      "fields": {
        "device_id": {
          "name": "Device ID",
          "description": "The device identifier"
        },
        "duration": {
          "name": "Duration",
          "description": "Duration in hours (1-24)"
        }
      }
    },
    "cancel_extra_hot_water": {
      "name": "Cancel extra hot water",
      "description": "Cancels active extra hot water mode",
      "fields": {
        "device_id": {
          "name": "Device ID",
          "description": "The device identifier"
        }
      }
    },
    "set_access_level": {
      "name": "Set access level",
      "description": "Sets the service access level for a specific device",
      "fields": {
        "config_entry_id": {
          "name": "Config entry ID",
          "description": "The ID of the Qvantum config entry that owns the device"
        },
        "device_id": {
          "name": "Device ID",
          "description": "The device identifier"
        },
        "access_level": {
          "name": "Access level",
          "description": "The access level to set (e.g. \"service\" or \"user\")"
        }
      }
    },
    "toggle_auto_elevate": {
      "name": "Toggle auto-elevate",
      "description": "Enables or disables automatic access-level elevation for a device",
      "fields": {
        "config_entry_id": {
          "name": "Config entry ID",
          "description": "The ID of the Qvantum config entry that owns the device"
        },
        "device_id": {
          "name": "Device ID",
          "description": "The device identifier"
        },
        "enable": {
          "name": "Enable",
          "description": "Set to true to enable auto-elevate, false to disable"
        }
      }
    }
  },
  "exceptions": {
    "setup_no_devices": {
